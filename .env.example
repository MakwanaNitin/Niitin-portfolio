# EmailJS credentials — required for the Contact form to actually send email.
# Sending will NOT work until every value below is filled in with a real
# EmailJS account. This is not optional configuration — Gmail does not
# allow a static frontend site to send mail on its own, so EmailJS acts as
# the authenticated bridge between the form and your inbox.
#
# 1. Create a free account at https://www.emailjs.com
# 2. Add an Email Service (e.g. Gmail) -> copy the "Service ID"
# 3. Create an Email Template with:
#      - "To Email" field set to: nitinmakwana623@gmail.com  (or {{to_email}})
#      - Subject: New Portfolio Contact Message
#      - Body using these variables:
#
#          From: {{from_name}} <{{from_email}}>
#          Subject: {{subject}}
#          Message: {{message}}
#          Sent: {{time}}
#
#    -> copy the "Template ID"
# 4. Go to Account > General -> copy your "Public Key"
# 5. Copy this file to ".env" (same folder) and fill in the three values
# 6. Restart the dev server (or redeploy) after editing .env

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Recipient inbox — set here for reference/{{to_email}} use, but the real
# destination is controlled by the "To Email" field in your EmailJS template.
VITE_EMAILJS_TO_EMAIL=nitinmakwana623@gmail.com
